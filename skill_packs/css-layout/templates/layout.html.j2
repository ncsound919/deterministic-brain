<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>{{ layout_type or "Grid" }} Layout</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body {
  background: #0a0a0f; color: #e4e4ec;
  font-family: system-ui, sans-serif; min-height: 100vh;
  padding: 40px;
}
h1 { text-align: center; margin-bottom: 32px; color: #00ffe7; font-size: 28px; }

{% if layout_type == "flex" or layout_type == "row" %}
.layout {
  display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
}
.layout > div {
  background: #13131a; border: 1px solid #1e1e2e; border-radius: 12px;
  padding: 32px; min-width: 200px; flex: 1 1 250px; text-align: center;
  transition: all .2s;
}
.layout > div:hover { border-color: #00ffe7; transform: translateY(-2px); }
{% elif layout_type == "sidebar" %}
.wrapper { display: flex; gap: 16px; min-height: 80vh; }
.sidebar {
  background: #13131a; border: 1px solid #1e1e2e; border-radius: 12px;
  padding: 24px; width: 240px; flex-shrink: 0;
}
.main {
  background: #13131a; border: 1px solid #1e1e2e; border-radius: 12px;
  padding: 24px; flex: 1;
}
{% elif layout_type == "grid" or layout_type == "dashboard" %}
.layout {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.layout > div {
  background: #13131a; border: 1px solid #1e1e2e; border-radius: 12px;
  padding: 32px; text-align: center; min-height: 160px;
  transition: all .2s;
}
.layout > div:hover { border-color: #00ffe7; transform: translateY(-2px); }
.layout > div.span-2 { grid-column: span 2; }
{% else %}
.layout {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.layout > div {
  background: #13131a; border: 1px solid #1e1e2e; border-radius: 12px;
  padding: 32px; text-align: center;
  transition: all .2s;
}
.layout > div:hover { border-color: #00ffe7; transform: translateY(-2px); }
{% endif %}

h3 { color: #bf5fff; font-size: 16px; margin-bottom: 8px; }
p { color: #6c6c80; font-size: 13px; }
</style>
</head>
<body>
<h1>{{ layout_type or "Grid" }} Layout</h1>
<div class="{% if layout_type == 'sidebar' %}wrapper{% else %}layout{% endif %}">
  {% if layout_type == "sidebar" %}
  <div class="sidebar"><h3>Sidebar</h3><p>Navigation and filters</p></div>
  <div class="main"><h3>Main Content</h3><p>Primary content area</p></div>
  {% else %}
  <div><h3>Panel 1</h3><p>Content block</p></div>
  <div class="{% if layout_type == 'grid' or layout_type == 'dashboard' %}span-2{% endif %}"><h3>Panel 2</h3><p>Content block</p></div>
  <div><h3>Panel 3</h3><p>Content block</p></div>
  <div><h3>Panel 4</h3><p>Content block</p></div>
  {% endif %}
</div>
</body>
</html>
