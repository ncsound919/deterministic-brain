# ── Y O U ──────────────────────────────────────────────────────────
# This is your soul file. The brain reads it on every boot to understand:
#   WHO you are, WHY you build, HOW you like things done.
#
# Fill in what matters. The system fills in the rest.
# ─────────────────────────────────────────────────────────────────────

identity:
  name: ""                # e.g. "Tori"
  role: "developer"       # developer | researcher | creator | operator
  timezone: "UTC"
  pronouns: ""

agenda:
  mission: ""             # One-liner: what are you building toward?
  goals:                  # Concrete goals the brain should optimize for
    - ""
  anti_goals:             # Things to actively avoid
    - ""

  autonomous_directives:  # What auto systems (AutoDream, KAIROS) should do unprompted
    - "consolidate knowledge weekly"
    - "suggest skill improvements when patterns emerge"
    - ""

context:
  expertise:              # What you already know well
    - ""
  learning:               # What you're currently learning
    - ""
  stack:                  # Your preferred tools
    languages: []
    frameworks: []
    tools: []
  notes: ""               # Freeform context the brain should always remember

preferences:
  code_style: ""          # e.g. "functional, typed, minimal comments"
  naming: ""              # e.g. "kebab-case files, camelCase functions"
  testing: ""             # e.g. "TDD, pytest, 80% coverage minimum"
  deploy: ""              # e.g. "Docker, AWS, auto-deploy on merge"

  communication:
    verbosity: "concise"  # concise | detailed | verbose
    tone: "direct"        # direct | friendly | academic | casual

knowledge_sources:         # URLs the brain should auto-ingest on boot
  - ""
  - ""

project_templates:         # Paths to .md/.yaml/.json templates for scaffolding
  - ""

# ── Generated by brain (don't edit below) ───────────────────────────
meta:
  version: "1.0"
  created: ""
  updated: ""
  sessions: 0
