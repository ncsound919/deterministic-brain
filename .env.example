# =============================================================================
# Deterministic Brain — Environment Configuration
# Copy to .env and fill in your values.
# =============================================================================

# --- OpenRouter (primary LLM backbone) ---
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_SITE_URL=https://github.com/ncsound919/deterministic-brain
OPENROUTER_SITE_NAME=deterministic-brain

# --- Per-lane model overrides (all routed via OpenRouter) ---
# Defaults shown — change to any model slug from https://openrouter.ai/models
MODEL_CODING=openai/o3
MODEL_OPENCODE=openai/o3
MODEL_BUSINESS_LOGIC=anthropic/claude-opus-4
MODEL_AGENT_BRAIN=anthropic/claude-sonnet-4-5
MODEL_TOOL_CALLING=meta-llama/llama-3.3-70b-instruct
MODEL_CROSS_DOMAIN=google/gemini-2.5-pro
MODEL_DEFAULT=openai/gpt-4o

# --- Local LLM fallback (llama.cpp / GGUF) ---
# Only used if OPENROUTER_API_KEY is not set.
QWEN_MODEL_PATH=./models/qwen3-coder-q4_k_m.gguf
LLM_CTX_SIZE=4096
LLM_MAX_TOKENS=2048
LLM_SEED=42

# --- Qdrant vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=main
RETRIEVAL_TOP_K=5

# --- Neo4j knowledge graph ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here
NEO4J_DEPTH=1

# --- Tavily web search ---
TAVILY_API_KEY=your_tavily_key_here
TAVILY_MAX_RESULTS=3

# --- Browser control ---
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=10000

# --- MCTS reasoning ---
MCTS_SIMULATIONS=20
MCTS_BRANCH_FACTOR=3
MCTS_MAX_DEPTH=4

# --- Tracing ---
TRACING_ENABLED=true
CHECKPOINT_DIR=.checkpoints

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000

# --- App ---
DEBUG=false
LOG_LEVEL=INFO
